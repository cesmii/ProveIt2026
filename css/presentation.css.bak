}

.logo-schneider {
    width: 324px;
    height: 108px;
}

.logo-inductive-cmapi {
    width: 189px;
    height: 63px;
}

.logo-rockwell {
    width: 324px;
    height: 108px;
}

.logo-sas {
    width: 151px;
    height: 50px;
}

.logo-highbyte-cmapi {
    width: 324px;
